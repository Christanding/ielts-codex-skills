{
  "name": "ielts-dashboard",
  "version": "1.0.0",
  "description": "IELTS V1.0 local dashboard — visualize your ~/.ielts/ data",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "concurrently -k -n server,web -c blue,green \"npm:backend\" \"npm:frontend\"",
    "backend": "node server.js",
    "frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node scripts/seed-demo-data.js",
    "validate": "node scripts/validate.js",
    "backfill": "node scripts/backfill-score-metadata.js",
    "migrate": "node scripts/migrate-to-v1-0.js",
    "reset": "node scripts/reset.js",
    "backup": "node scripts/backup.js"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "recharts": "^2.15.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.6",
    "vite": "^6.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
